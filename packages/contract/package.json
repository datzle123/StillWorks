{
  "name": "@mergevow/contract",
  "version": "0.0.0",
  "private": true,
  "description": "Data-only behavior contracts for MergeVow.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "schema"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schema/contract-v1.schema.json": "./schema/contract-v1.schema.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && tsc -b tsconfig.build.json && node -e \"require('node:fs').copyFileSync('schema/contract-v1.schema.json', 'dist/schema/contract-v1.schema.json')\"",
    "clean": "node -e \"const { rmSync } = require('node:fs'); rmSync('dist', { recursive: true, force: true }); rmSync('.tsbuildinfo', { force: true })\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "canonicalize": "3.0.0",
    "jsonc-parser": "3.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
